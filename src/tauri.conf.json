{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2-docs/main/schemas/config.schema.json",
  "productName": "AIM",
  "version": "0.1.6",
  "identifier": "com.aim.agent-instances-manager",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:7878"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "AIM — Agent Instances Manager",
        "width": 1200,
        "height": 800,
        "visible": false,
        "url": "http://localhost:7878/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "resources/*": "./"
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {}
}
